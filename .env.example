PORT=3000
# Local Node entrypoints load repo-root .env automatically. Do not commit real .env files.
PLATFORM_DB_FILE=var/db/platform.sqlite
OBJECT_STORE_DIR=var/object-store
LOCAL_BACKUP_DIR=var/backups
LOCAL_DELIVERY_DIR=var/delivery
LOCAL_OPS_DIR=var/ops
RUNTIME_MODE=local
LOCAL_STORAGE_ONLY=1

# Render runtime. stub-image is safe for local/no-key work and marks output as non-final placeholders.
RENDER_PROVIDER=stub-image
RENDER_PROVIDER_API_KEY=

# Backend-only OpenAI settings. Never expose OPENAI_API_KEY to frontend code.
OPENAI_API_KEY=
OPENAI_RENDER_MODEL=gpt-image-2
OPENAI_RESEARCH_MODEL=gpt-5.2

# ClinicalEducation compatibility: reuse the old app's OpenAI vector store and model knobs.
KB_VECTOR_STORE_ID=
MMS_MODEL=gpt-5.2

# ClinicalEducation compatibility: canonical story and visual profile inputs.
MMS_CANON_ROOT=
MMS_CHARACTER_BIBLE_PATH=
MMS_SERIES_STYLE_BIBLE_PATH=
MMS_DECK_SPEC_PATH=
MMS_EPISODE_MEMORY_PATH=
MMS_DISABLE_CANON_AUTO_DISCOVERY=0

# ClinicalEducation compatibility: local pipeline controls retained from the old app.
MAX_CONCURRENT_RUNS=1
MMS_RUN_RETENTION_KEEP_LAST=50
MMS_PIPELINE_MODE=real
MMS_FAKE_STEP_DELAY_MS=80
MMS_V2_KB0_TIMEOUT_MS=120000
MMS_V2_STEP_AB_AGENT_TIMEOUT_MS=120000
MMS_V2_STEP_C_AGENT_TIMEOUT_MS=180000
MMS_V2_STEP_C_DECKSPEC_TIMEOUT_MS=300000
MMS_V2_AGENT_ISOLATION_MODE=
MMS_DETECTIVE_LEAD_NAME=Detective Cyto Kine
MMS_DETECTIVE_DEPUTY_NAME=Deputy Pip

# Active runtime is local-only. Managed-looking values are ignored by the app runtime for this phase.
METADATA_STORE_BACKEND=sqlite
OBJECT_STORE_BACKEND=filesystem
ASYNC_QUEUE_BACKEND=in-process
TELEMETRY_BACKEND=stdout

# Optional archived portability checks only. Not required for the active local-storage app path.
RESTORE_SMOKE_DRY_RUN=0
