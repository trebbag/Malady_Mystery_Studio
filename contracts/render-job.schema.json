{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/render-job.schema.json",
  "title": "RenderJob",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "tenantId",
    "workflowRunId",
    "status",
    "queueName",
    "provider",
    "model",
    "renderTargetProfileId",
    "renderPromptIds",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "tenantId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "workflowRunId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "completed",
        "retry-required",
        "failed"
      ]
    },
    "approvalStatus": {
      "type": "string",
      "enum": [
        "pending",
        "approved",
        "rejected"
      ]
    },
    "queueName": {
      "type": "string"
    },
    "provider": {
      "type": "string"
    },
    "model": {
      "type": "string"
    },
    "renderTargetProfileId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "renderPromptIds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "attemptIds": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "renderedAssetManifestId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "startedAt": {
      "type": "string",
      "format": "date-time"
    },
    "activeRenderPromptId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "completedRenderPromptIds": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "completedRenderCount": {
      "type": "integer",
      "minimum": 0
    },
    "totalRenderCount": {
      "type": "integer",
      "minimum": 0
    },
    "lastError": {
      "type": "string"
    },
    "createdBy": {
      "type": "string"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "completedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
