{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/workflow-run.schema.json",
  "title": "WorkflowRun",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "projectId",
    "input",
    "state",
    "currentStage",
    "requiredApprovalRoles",
    "stages",
    "artifacts",
    "approvals",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "projectId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "tenantId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "diseaseName"
      ],
      "properties": {
        "diseaseName": {
          "type": "string"
        },
        "audienceTier": {
          "type": "string"
        },
        "lengthProfile": {
          "type": "string"
        },
        "qualityProfile": {
          "type": "string"
        },
        "styleProfile": {
          "type": "string"
        }
      }
    },
    "state": {
      "type": "string",
      "enum": [
        "draft",
        "running",
        "review",
        "approved",
        "exported",
        "failed",
        "cancelled"
      ]
    },
    "currentStage": {
      "type": "string",
      "enum": [
        "intake",
        "canonicalization",
        "research-assembly",
        "disease-packet",
        "story-workbook",
        "scene-planning",
        "panel-planning",
        "render-prep",
        "render-execution",
        "review",
        "export"
      ]
    },
    "requiredApprovalRoles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "clinical",
          "editorial",
          "product",
          "security"
        ]
      }
    },
    "stages": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "status"
        ],
        "properties": {
          "name": {
            "type": "string",
            "enum": [
              "intake",
              "canonicalization",
              "research-assembly",
              "disease-packet",
              "story-workbook",
              "scene-planning",
              "panel-planning",
              "render-prep",
              "render-execution",
              "review",
              "export"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "running",
              "passed",
              "failed",
              "blocked"
            ]
          },
          "startedAt": {
            "type": "string",
            "format": "date-time"
          },
          "endedAt": {
            "type": "string",
            "format": "date-time"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifactType",
          "artifactId",
          "status"
        ],
        "properties": {
          "artifactType": {
            "type": "string",
            "enum": [
              "project",
              "canonical-disease",
              "canonicalization-resolution",
              "research-brief",
              "source-harvest",
              "knowledge-pack-build-report",
              "disease-knowledge-pack",
              "knowledge-pack-promotion-decision",
              "disease-packet",
              "fact-table",
              "evidence-graph",
              "clinical-teaching-points",
              "visual-anchor-catalog",
              "story-workbook",
              "story-memory",
              "narrative-review-trace",
              "scene-card",
              "panel-plan",
              "render-prompt",
              "rendering-guide",
              "render-job",
              "render-attempt",
              "rendered-asset",
              "rendered-asset-manifest",
              "lettering-map",
              "qa-report",
              "eval-run",
              "release-bundle",
              "work-item",
              "review-thread",
              "review-message",
              "source-owner-assignment",
              "source-refresh-task"
            ]
          },
          "artifactId": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "generated",
              "approved",
              "rejected",
              "exported"
            ]
          },
          "path": {
            "type": "string"
          }
        }
      }
    },
    "approvals": {
      "type": "array",
      "items": {
        "$ref": "approval-decision.schema.json"
      }
    },
    "lastEventId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "pauseReason": {
      "type": "string",
      "enum": [
        "clinical-governance-review-required",
        "clinical-governance-blocked",
        "provisional-knowledge-pack-review-required",
        "source-refresh-required",
        "render-retry-required"
      ]
    },
    "activeWorkItemCount": {
      "type": "integer",
      "minimum": 0
    },
    "overdueWorkItemCount": {
      "type": "integer",
      "minimum": 0
    },
    "latestEvalRunId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "latestEvalStatus": {
      "type": "string",
      "enum": [
        "missing",
        "passed",
        "failed",
        "stale"
      ]
    },
    "latestEvalAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
