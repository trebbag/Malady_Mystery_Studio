{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/export-history-view.schema.json",
  "title": "ExportHistoryView",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "runId",
    "entries"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "runId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "export-history-entry.schema.json"
      }
    }
  }
}
