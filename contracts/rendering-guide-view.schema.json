{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/rendering-guide-view.schema.json",
  "title": "RenderingGuideView",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "runId",
    "renderingGuide",
    "markdown",
    "attachmentSummary",
    "visualReferencePack",
    "reviewDecision",
    "gateStatus",
    "renderDisabledReason",
    "guideWarnings",
    "availableActions"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "runId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "renderingGuide": {
      "$ref": "rendering-guide.schema.json"
    },
    "markdown": {
      "type": "string"
    },
    "attachmentSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "attachedRenderedAssetCount",
        "attachmentMode"
      ],
      "properties": {
        "attachedRenderedAssetCount": {
          "type": "integer",
          "minimum": 0
        },
        "latestRenderedAssetManifestId": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "attachmentMode": {
          "type": "string",
          "enum": [
            "guide-only",
            "external-art-attached"
          ]
        }
      }
    },
    "visualReferencePack": {
      "anyOf": [
        { "$ref": "visual-reference-pack.schema.json" },
        { "type": "null" }
      ]
    },
    "reviewDecision": {
      "anyOf": [
        { "$ref": "render-guide-review-decision.schema.json" },
        { "type": "null" }
      ]
    },
    "gateStatus": {
      "type": "string",
      "enum": [
        "not-reviewed",
        "approved",
        "changes-requested",
        "rejected",
        "stale",
        "missing-guide",
        "missing-reference-pack"
      ]
    },
    "renderDisabledReason": {
      "type": "string"
    },
    "guideWarnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "availableActions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
