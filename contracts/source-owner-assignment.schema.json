{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/source-owner-assignment.schema.json",
  "title": "SourceOwnerAssignment",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "tenantId",
    "sourceId",
    "canonicalDiseaseName",
    "primaryOwnerRole",
    "backupOwnerRole",
    "assignedBy",
    "assignedAt"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "tenantId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "sourceId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "canonicalDiseaseName": {
      "type": "string"
    },
    "primaryOwnerRole": {
      "type": "string"
    },
    "backupOwnerRole": {
      "type": "string"
    },
    "assignedBy": {
      "type": "string"
    },
    "assignedAt": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
