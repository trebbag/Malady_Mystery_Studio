{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/source-refresh-task.schema.json",
  "title": "SourceRefreshTask",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "tenantId",
    "sourceId",
    "canonicalDiseaseName",
    "status",
    "reason",
    "freshnessState",
    "nextReviewDueAt",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "tenantId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "workflowRunId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "sourceId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "canonicalDiseaseName": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "in-progress",
        "completed",
        "cancelled"
      ]
    },
    "reason": {
      "type": "string"
    },
    "freshnessState": {
      "type": "string",
      "enum": [
        "current",
        "aging",
        "stale",
        "blocked"
      ]
    },
    "workItemId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "nextReviewDueAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "completedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
