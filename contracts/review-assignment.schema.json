{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/review-assignment.schema.json",
  "title": "ReviewAssignment",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "tenantId",
    "workflowRunId",
    "reviewRole",
    "assigneeId",
    "assigneeDisplayName",
    "assigneeRoles",
    "status",
    "assignedBy",
    "assignedByRoles",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "tenantId": {
      "type": "string"
    },
    "workflowRunId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "reviewRole": {
      "type": "string"
    },
    "assigneeId": {
      "type": "string"
    },
    "assigneeDisplayName": {
      "type": "string"
    },
    "assigneeRoles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "in-progress",
        "completed",
        "reassigned"
      ]
    },
    "dueAt": {
      "type": "string",
      "format": "date-time"
    },
    "completedAt": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": "string"
    },
    "assignedBy": {
      "type": "string"
    },
    "assignedByRoles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
