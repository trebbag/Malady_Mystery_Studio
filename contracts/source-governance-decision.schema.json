{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/source-governance-decision.schema.json",
  "title": "SourceGovernanceDecision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "tenantId",
    "sourceId",
    "canonicalDiseaseName",
    "decision",
    "decidedBy",
    "occurredAt"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "tenantId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "sourceId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "canonicalDiseaseName": {
      "type": "string"
    },
    "decision": {
      "type": "string",
      "enum": [
        "approved",
        "conditional",
        "suspended",
        "refresh-review-date",
        "superseded"
      ]
    },
    "supersededBy": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "reason": {
      "type": "string"
    },
    "reviewedAt": {
      "type": "string",
      "format": "date-time"
    },
    "decidedBy": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "decidedByRoles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
