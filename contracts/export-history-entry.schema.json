{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/export-history-entry.schema.json",
  "title": "ExportHistoryEntry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "releaseId",
    "workflowRunId",
    "tenantId",
    "exportedBy",
    "exportedAt",
    "status",
    "bundleLocation",
    "bundleIndexLocation",
    "exportTargets"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "releaseId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "workflowRunId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "tenantId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "exportedBy": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "exportedAt": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "completed",
        "failed"
      ]
    },
    "bundleLocation": {
      "type": "string"
    },
    "bundleIndexLocation": {
      "type": "string"
    },
    "exportTargets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
