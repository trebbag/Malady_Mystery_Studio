{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/review-queue-analytics-view.schema.json",
  "title": "ReviewQueueAnalyticsView",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "summary",
    "countsByWorkType",
    "countsByStatus",
    "countsByPriority",
    "assigneeLoad",
    "runBlockersByStage",
    "overdueAgingBuckets",
    "slaBuckets",
    "sourceRefreshBurden",
    "threadResolution"
  ],
  "properties": {
    "schemaVersion": { "type": "string" },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "totalItemCount",
        "overdueItemCount",
        "escalatedItemCount",
        "overdueRate",
        "escalationRate",
        "medianAgeHours",
        "dueSoonItemCount",
        "completedItemCount",
        "fallbackQueueItemCount",
        "unreadNotificationCount",
        "unresolvedMentionCount",
        "sourceRefreshOpenCount",
        "renderRetryOpenCount",
        "opsDrillOpenCount",
        "medianThreadResolutionHours"
      ],
      "properties": {
        "totalItemCount": { "type": "integer", "minimum": 0 },
        "overdueItemCount": { "type": "integer", "minimum": 0 },
        "escalatedItemCount": { "type": "integer", "minimum": 0 },
        "overdueRate": { "type": "number", "minimum": 0, "maximum": 1 },
        "escalationRate": { "type": "number", "minimum": 0, "maximum": 1 },
        "medianAgeHours": { "type": "number", "minimum": 0 },
        "dueSoonItemCount": { "type": "integer", "minimum": 0 },
        "completedItemCount": { "type": "integer", "minimum": 0 },
        "fallbackQueueItemCount": { "type": "integer", "minimum": 0 },
        "unreadNotificationCount": { "type": "integer", "minimum": 0 },
        "unresolvedMentionCount": { "type": "integer", "minimum": 0 },
        "sourceRefreshOpenCount": { "type": "integer", "minimum": 0 },
        "renderRetryOpenCount": { "type": "integer", "minimum": 0 },
        "opsDrillOpenCount": { "type": "integer", "minimum": 0 },
        "medianThreadResolutionHours": { "type": "number", "minimum": 0 }
      }
    },
    "countsByWorkType": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["workType", "count"],
        "properties": {
          "workType": { "type": "string" },
          "count": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "countsByStatus": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["status", "count"],
        "properties": {
          "status": { "type": "string" },
          "count": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "countsByPriority": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["priority", "count"],
        "properties": {
          "priority": { "type": "string" },
          "count": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "assigneeLoad": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["assignee", "count"],
        "properties": {
          "assignee": { "type": "string" },
          "count": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "runBlockersByStage": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["stage", "count"],
        "properties": {
          "stage": { "type": "string" },
          "count": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "overdueAgingBuckets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["bucket", "count"],
        "properties": {
          "bucket": { "type": "string" },
          "count": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "slaBuckets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["bucket", "count"],
        "properties": {
          "bucket": { "type": "string" },
          "count": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "sourceRefreshBurden": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["canonicalDiseaseName", "ownerRole", "openCount", "overdueCount"],
        "properties": {
          "canonicalDiseaseName": { "type": "string" },
          "ownerRole": { "type": "string" },
          "openCount": { "type": "integer", "minimum": 0 },
          "overdueCount": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "threadResolution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["openThreadCount", "resolvedThreadCount", "medianResolutionHours"],
      "properties": {
        "openThreadCount": { "type": "integer", "minimum": 0 },
        "resolvedThreadCount": { "type": "integer", "minimum": 0 },
        "medianResolutionHours": { "type": "number", "minimum": 0 }
      }
    }
  }
}
