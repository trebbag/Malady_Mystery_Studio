{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/rendered-asset-manifest.schema.json",
  "title": "RenderedAssetManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "tenantId",
    "workflowRunId",
    "renderJobId",
    "renderTargetProfileId",
    "renderedAssets",
    "allPanelsRendered",
    "generatedAt"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "tenantId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "workflowRunId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "renderJobId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "renderTargetProfileId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "renderingGuideId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "visualReferencePackId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "allPanelsRendered": {
      "type": "boolean"
    },
    "renderMode": {
      "type": "string",
      "enum": [
        "live-provider",
        "stub-placeholder",
        "external-manual"
      ]
    },
    "nonFinalPlaceholder": {
      "type": "boolean"
    },
    "providerNotice": {
      "type": "string"
    },
    "renderedAssets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "renderedAssetId",
          "renderPromptId",
          "panelId",
          "location",
          "checksum",
          "mimeType"
        ],
        "properties": {
          "renderedAssetId": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "renderPromptId": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "panelId": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "location": {
            "type": "string"
          },
          "checksum": {
            "type": "string"
          },
          "mimeType": {
            "type": "string"
          },
          "isPlaceholder": {
            "type": "boolean"
          },
          "promptHash": {
            "type": "string"
          },
          "retryStrategy": {
            "type": "string",
            "enum": [
              "baseline",
              "simplified-composition",
              "tight-anatomy"
            ]
          },
          "letteringSeparationStatus": {
            "type": "string",
            "enum": [
              "passed",
              "failed"
            ]
          },
          "continuityLockCount": {
            "type": "integer",
            "minimum": 0
          },
          "anatomyLockCount": {
            "type": "integer",
            "minimum": 0
          },
          "acceptanceCheckCount": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "localValidation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "structuralOnly",
        "requiredPanelCount",
        "renderedPanelCount",
        "panelPromptHashes",
        "letteringSeparationPassed",
        "continuityLocksPresent",
        "anatomyLocksPresent"
      ],
      "properties": {
        "structuralOnly": {
          "type": "boolean"
        },
        "requiredPanelCount": {
          "type": "integer",
          "minimum": 0
        },
        "renderedPanelCount": {
          "type": "integer",
          "minimum": 0
        },
        "panelPromptHashes": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "letteringSeparationPassed": {
          "type": "boolean"
        },
        "continuityLocksPresent": {
          "type": "boolean"
        },
        "anatomyLocksPresent": {
          "type": "boolean"
        }
      }
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
