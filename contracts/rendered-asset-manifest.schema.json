{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/rendered-asset-manifest.schema.json",
  "title": "RenderedAssetManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "tenantId",
    "workflowRunId",
    "renderJobId",
    "renderTargetProfileId",
    "renderedAssets",
    "allPanelsRendered",
    "generatedAt"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "tenantId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "workflowRunId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "renderJobId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "renderTargetProfileId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "allPanelsRendered": {
      "type": "boolean"
    },
    "renderedAssets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "renderedAssetId",
          "renderPromptId",
          "panelId",
          "location",
          "checksum",
          "mimeType"
        ],
        "properties": {
          "renderedAssetId": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "renderPromptId": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "panelId": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "location": {
            "type": "string"
          },
          "checksum": {
            "type": "string"
          },
          "mimeType": {
            "type": "string"
          }
        }
      }
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
