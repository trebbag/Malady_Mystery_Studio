{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/review-comment.schema.json",
  "title": "ReviewComment",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "tenantId",
    "workflowRunId",
    "scopeType",
    "status",
    "severity",
    "body",
    "reviewerId",
    "reviewerDisplayName",
    "reviewerRoles",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "tenantId": {
      "type": "string"
    },
    "workflowRunId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "scopeType": {
      "type": "string",
      "enum": [
        "run",
        "artifact"
      ]
    },
    "artifactType": {
      "type": "string"
    },
    "artifactId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "fieldPath": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "resolved",
        "note"
      ]
    },
    "severity": {
      "type": "string",
      "enum": [
        "info",
        "warning",
        "critical"
      ]
    },
    "body": {
      "type": "string",
      "minLength": 1
    },
    "reviewerId": {
      "type": "string"
    },
    "reviewerDisplayName": {
      "type": "string"
    },
    "reviewerRoles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "resolvedAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object"
    }
  }
}
