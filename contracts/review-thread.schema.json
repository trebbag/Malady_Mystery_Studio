{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/review-thread.schema.json",
  "title": "ReviewThread",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "tenantId",
    "workflowRunId",
    "scopeType",
    "title",
    "status",
    "createdBy",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "tenantId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "workflowRunId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "scopeType": {
      "type": "string",
      "enum": [
        "run",
        "stage",
        "artifact",
        "source",
        "render-job"
      ]
    },
    "scopeId": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "resolved",
        "archived"
      ]
    },
    "participantIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "createdBy": {
      "type": "string"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "resolvedAt": {
      "type": "string",
      "format": "date-time"
    },
    "messages": {
      "type": "array",
      "items": {
        "$ref": "review-message.schema.json"
      }
    }
  }
}
