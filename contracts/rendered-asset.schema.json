{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/rendered-asset.schema.json",
  "title": "RenderedAsset",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "tenantId",
    "workflowRunId",
    "renderJobId",
    "renderPromptId",
    "panelId",
    "provider",
    "model",
    "mimeType",
    "checksum",
    "location",
    "createdAt"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "tenantId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "workflowRunId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "renderJobId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "renderPromptId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "panelId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "provider": {
      "type": "string"
    },
    "model": {
      "type": "string"
    },
    "mimeType": {
      "type": "string"
    },
    "checksum": {
      "type": "string"
    },
    "location": {
      "type": "string"
    },
    "thumbnailLocation": {
      "type": "string"
    },
    "width": {
      "type": "integer",
      "minimum": 1
    },
    "height": {
      "type": "integer",
      "minimum": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
