{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/review-message.schema.json",
  "title": "ReviewMessage",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "threadId",
    "tenantId",
    "workflowRunId",
    "authorId",
    "authorDisplayName",
    "body",
    "status",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "threadId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "tenantId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "workflowRunId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "parentMessageId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "authorId": {
      "type": "string"
    },
    "authorDisplayName": {
      "type": "string"
    },
    "body": {
      "type": "string"
    },
    "mentions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "mentionedActorIds": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "posted",
        "edited",
        "resolved"
      ]
    },
    "resolutionNote": {
      "type": "string"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "resolvedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
