{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/project.schema.json",
  "title": "Project",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "title",
    "status",
    "input",
    "workflowRunIds",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "tenantId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "title": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "archived"
      ]
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "diseaseName"
      ],
      "properties": {
        "diseaseName": {
          "type": "string"
        },
        "audienceTier": {
          "type": "string"
        },
        "lengthProfile": {
          "type": "string"
        },
        "qualityProfile": {
          "type": "string"
        },
        "styleProfile": {
          "type": "string"
        }
      }
    },
    "activeWorkflowRunId": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "workflowRunIds": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
