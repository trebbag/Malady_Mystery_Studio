{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/review-run-view.schema.json",
  "title": "ReviewRunView",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "runId",
    "projectTitle",
    "diseaseName",
    "state",
    "currentStage",
    "stageTimeline",
    "clinicalPackage",
    "reviewAssignments",
    "reviewComments",
    "workItems",
    "reviewThreads",
    "evaluationSummary",
    "exportHistory",
    "availableActions"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "runId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "projectTitle": {
      "type": "string"
    },
    "diseaseName": {
      "type": "string"
    },
    "state": {
      "type": "string"
    },
    "currentStage": {
      "type": "string"
    },
    "pauseReason": {
      "type": "string"
    },
    "stageTimeline": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "status"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "clinicalPackage": {
      "$ref": "clinical-package-view.schema.json"
    },
    "reviewAssignments": {
      "type": "array",
      "items": {
        "$ref": "review-assignment.schema.json"
      }
    },
    "reviewComments": {
      "type": "array",
      "items": {
        "$ref": "review-comment.schema.json"
      }
    },
    "workItems": {
      "type": "array",
      "items": {
        "$ref": "work-item.schema.json"
      }
    },
    "reviewThreads": {
      "type": "array",
      "items": {
        "$ref": "review-thread.schema.json"
      }
    },
    "evaluationSummary": {
      "$ref": "evaluation-summary-view.schema.json"
    },
    "exportHistory": {
      "$ref": "export-history-view.schema.json"
    },
    "renderJobs": {
      "type": "array",
      "items": {
        "$ref": "render-job.schema.json"
      }
    },
    "availableActions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
