{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/contradiction-resolution.schema.json",
  "title": "ContradictionResolution",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "tenantId",
    "canonicalDiseaseName",
    "claimId",
    "status",
    "resolvedBy",
    "occurredAt"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "tenantId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "canonicalDiseaseName": {
      "type": "string"
    },
    "claimId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "relatedClaimId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "monitor",
        "blocking",
        "resolved"
      ]
    },
    "reason": {
      "type": "string"
    },
    "resolvedBy": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "resolvedByRoles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
