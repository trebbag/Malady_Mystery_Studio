{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/visual-anchor-catalog.schema.json",
  "title": "VisualAnchorCatalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "canonicalDiseaseName",
    "anchors"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "canonicalDiseaseName": {
      "type": "string"
    },
    "anchors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "anchorId",
          "title",
          "bodyScale",
          "location",
          "description",
          "linkedClaimIds"
        ],
        "properties": {
          "anchorId": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "title": {
            "type": "string"
          },
          "bodyScale": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "linkedClaimIds": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z0-9._:-]+$"
            }
          }
        }
      }
    }
  }
}
