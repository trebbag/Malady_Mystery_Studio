{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/auth-session.schema.json",
  "title": "AuthSession",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "tenantId",
    "userId",
    "authMethod",
    "expiresAt",
    "createdAt",
    "lastSeenAt"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "tenantId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "userId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "authMethod": {
      "type": "string",
      "enum": [
        "local-password",
        "oidc-hs256"
      ]
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "lastSeenAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
