{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/narrative-review-trace.schema.json",
  "title": "NarrativeReviewTrace",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "subjectType",
    "subjectId",
    "rubricVersion",
    "scores",
    "findings",
    "verdict",
    "createdAt"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "subjectType": {
      "type": "string",
      "enum": [
        "story-workbook"
      ]
    },
    "subjectId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "rubricVersion": {
      "type": "string"
    },
    "scores": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mysteryIntegrity",
        "educationalSequencing",
        "novelty",
        "franchiseCompliance"
      ],
      "properties": {
        "mysteryIntegrity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "educationalSequencing": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "novelty": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "franchiseCompliance": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "category",
          "severity",
          "ruleId",
          "message"
        ],
        "properties": {
          "category": {
            "type": "string",
            "enum": [
              "mystery-integrity",
              "educational-sequencing",
              "novelty",
              "franchise-compliance"
            ]
          },
          "severity": {
            "type": "string",
            "enum": [
              "blocking",
              "warning",
              "info"
            ]
          },
          "ruleId": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "evidence": {
            "type": "string"
          },
          "recommendation": {
            "type": "string"
          }
        }
      }
    },
    "verdict": {
      "type": "string",
      "enum": [
        "pass",
        "conditional-pass",
        "fail"
      ]
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
