{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/knowledge-pack-promotion-decision.schema.json",
  "title": "KnowledgePackPromotionDecision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "tenantId",
    "workflowRunId",
    "knowledgePackId",
    "decision",
    "decidedBy",
    "decidedAt"
  ],
  "properties": {
    "schemaVersion": { "type": "string" },
    "id": { "type": "string", "pattern": "^[A-Za-z0-9._:-]+$" },
    "tenantId": { "type": "string", "pattern": "^[A-Za-z0-9._:-]+$" },
    "workflowRunId": { "type": "string", "pattern": "^[A-Za-z0-9._:-]+$" },
    "knowledgePackId": { "type": "string", "pattern": "^[A-Za-z0-9._:-]+$" },
    "decision": {
      "type": "string",
      "enum": ["approved-run-only", "promoted-to-library", "rejected"]
    },
    "notes": { "type": "string" },
    "decidedBy": { "type": "string" },
    "decidedByRoles": {
      "type": "array",
      "items": { "type": "string" }
    },
    "decidedAt": { "type": "string", "format": "date-time" }
  }
}
