{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/render-attempt.schema.json",
  "title": "RenderAttempt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "renderJobId",
    "workflowRunId",
    "tenantId",
    "attemptNumber",
    "strategy",
    "status",
    "startedAt"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "renderJobId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "workflowRunId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "tenantId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "attemptNumber": {
      "type": "integer",
      "minimum": 1
    },
    "strategy": {
      "type": "string",
      "enum": [
        "baseline",
        "simplified-composition",
        "tight-anatomy"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "running",
        "succeeded",
        "failed"
      ]
    },
    "providerRequestId": {
      "type": "string"
    },
    "renderedAssetIds": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "errorCode": {
      "type": "string"
    },
    "errorMessage": {
      "type": "string"
    },
    "startedAt": {
      "type": "string",
      "format": "date-time"
    },
    "completedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
