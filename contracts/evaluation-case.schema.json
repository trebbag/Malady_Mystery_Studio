{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/evaluation-case.schema.json",
  "title": "EvaluationCase",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "caseId",
    "evalFamily",
    "input",
    "expected",
    "forbidden",
    "graderNotes"
  ],
  "properties": {
    "caseId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "evalFamily": {
      "type": "string"
    },
    "input": {
      "type": "object"
    },
    "expected": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forbidden": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "graderNotes": {
      "type": "string"
    },
    "thresholdHint": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}