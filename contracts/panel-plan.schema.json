{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/panel-plan.schema.json",
  "title": "PanelPlan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "sceneId",
    "pageRange",
    "panels"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "sceneId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "pageRange": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "startPage",
        "endPage"
      ],
      "properties": {
        "startPage": {
          "type": "integer",
          "minimum": 1
        },
        "endPage": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "panels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "panelId",
          "order",
          "pageNumber",
          "storyFunction",
          "beatGoal",
          "medicalObjective",
          "location",
          "bodyScale",
          "charactersPresent",
          "actionSummary",
          "cameraFraming",
          "cameraAngle",
          "compositionNotes",
          "lightingMood",
          "renderIntent",
          "acceptanceChecks"
        ],
        "properties": {
          "panelId": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "order": {
            "type": "integer",
            "minimum": 1
          },
          "pageNumber": {
            "type": "integer",
            "minimum": 1
          },
          "storyFunction": {
            "type": "string"
          },
          "beatGoal": {
            "type": "string"
          },
          "medicalObjective": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "bodyScale": {
            "type": "string"
          },
          "charactersPresent": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "actionSummary": {
            "type": "string"
          },
          "clueRevealed": {
            "type": "string"
          },
          "continuityAnchors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "cameraFraming": {
            "type": "string"
          },
          "cameraAngle": {
            "type": "string"
          },
          "compositionNotes": {
            "type": "string"
          },
          "lightingMood": {
            "type": "string"
          },
          "humorOrTensionNote": {
            "type": "string"
          },
          "renderIntent": {
            "type": "string"
          },
          "acceptanceChecks": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}